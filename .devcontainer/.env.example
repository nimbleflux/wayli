# Wayli Dev Container Environment Variables
#
# This file is auto-generated on first Dev Container build by:
#   ./deploy/docker-compose/generate-keys.sh --stdout > .devcontainer/.env
#
# The .env file is NOT committed to version control.
# Copy this file to .env if you need to manually configure values.
#
# To regenerate secrets, delete .env and rebuild the Dev Container.

# URLs
SITE_URL=http://localhost:4000
FLUXBASE_PUBLIC_BASE_URL=http://localhost:8080
FLUXBASE_BASE_URL=http://fluxbase:8080

# Database
POSTGRES_PASSWORD=<auto-generated>

# JWT Configuration
FLUXBASE_AUTH_JWT_SECRET=<auto-generated>
FLUXBASE_ANON_KEY=<auto-generated>
FLUXBASE_SERVICE_ROLE_KEY=<auto-generated>

# Fluxbase Configuration
FLUXBASE_ENCRYPTION_KEY=<auto-generated>
FLUXBASE_SECURITY_SETUP_TOKEN=<auto-generated>
