############
# Wayli with Fluxbase - Environment Configuration
# YOU MUST CHANGE THESE BEFORE DEPLOYING TO PRODUCTION!
#
# TIP: Generate secrets with:
#   POSTGRES_PASSWORD=$(openssl rand -base64 32)
#   JWT_SECRET=$(openssl rand -base64 48)
#   MINIO_ROOT_PASSWORD=$(openssl rand -base64 32)
############

############
# REQUIRED SECRETS
# ⚠️  YOU MUST CHANGE THESE VALUES IN PRODUCTION!
############

# PostgreSQL Database password (REQUIRED)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# JWT Secret for Fluxbase authentication (REQUIRED)
# Must be at least 32 characters, recommended 48+ characters
# Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# MinIO S3-compatible storage credentials
# Generate with: openssl rand -base64 32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

############
# API Keys (Compatibility with Supabase SDK)
# These maintain compatibility with existing Wayli code patterns
############

# Anonymous API key - used for client-side requests
# In production, regenerate these using your JWT_SECRET!
# See: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6ImZsdXhiYXNlIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE3OTk1MzU2MDB9.iPr9o47ALu9iDLqL9rqq7rlvka9Q8ps2XV049R4l67E

# Service role API key - used for server-side admin operations
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiZmx1eGJhc2UiLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.2Sqa6QjzVSVUOkxrAQEGZshEyCDQxt2Ggx7v6y0lCBE

############
# Database Configuration
############

POSTGRES_USER=postgres
POSTGRES_DB=wayli
POSTGRES_PORT=5432

# Database Connection Pool Settings (Optional)
# Uncomment to customize - defaults shown in comments
# FLUXBASE_DATABASE_MAX_CONNECTIONS=25        # Maximum concurrent connections
# FLUXBASE_DATABASE_MIN_CONNECTIONS=5         # Minimum idle connections
# FLUXBASE_DATABASE_MAX_CONN_LIFETIME=1h      # Max connection lifetime
# FLUXBASE_DATABASE_MAX_CONN_IDLE_TIME=30m    # Max idle time before closing

############
# Fluxbase Server Configuration
############

# Fluxbase Docker image version
FLUXBASE_VERSION=latest

# Fluxbase server port (maps to internal container port 8080)
FLUXBASE_PORT=8080

# Internal URL for Fluxbase API (used by workers/server within Docker network)
# Uses Docker service name for internal container-to-container communication
FLUXBASE_BASE_URL=http://fluxbase-dev:8080

# Public URL for Fluxbase API (used by browser clients)
# ⚠️  Update this for production deployments!
PUBLIC_FLUXBASE_BASE_URL=http://localhost:8080

# Debug mode - enables verbose logging
# ⚠️  WARNING: Do not enable in production as it may log sensitive data
FLUXBASE_DEBUG=false

# Server Timeouts and Limits (Optional)
# Uncomment to customize - defaults shown in comments
# FLUXBASE_SERVER_READ_TIMEOUT=15s            # Max time to read request
# FLUXBASE_SERVER_WRITE_TIMEOUT=15s           # Max time to write response
# FLUXBASE_SERVER_IDLE_TIMEOUT=60s            # Keep-alive idle timeout
# FLUXBASE_SERVER_BODY_LIMIT=2147483648       # Max request body size (2GB)

############
# Authentication Configuration
############

# JWT access token expiry (examples: 15m, 1h, 24h)
# Shorter is more secure but requires more frequent refreshes
# Mapped to FLUXBASE_AUTH_JWT_EXPIRY in docker-compose
FLUXBASE_AUTH_JWT_EXPIRY=1h

# Refresh token expiry (examples: 24h, 168h, 720h)
# Default: 168h (7 days)
# FLUXBASE_AUTH_REFRESH_EXPIRY=168h

# Authentication Features (Optional)
# Uncomment to customize - defaults shown in comments
# FLUXBASE_AUTH_ENABLE_SIGNUP=true            # Allow new user registration
# FLUXBASE_AUTH_ENABLE_MAGIC_LINK=true        # Allow passwordless login
# FLUXBASE_AUTH_ENABLE_RLS=true               # Enable Row Level Security
# FLUXBASE_AUTH_PASSWORD_MIN_LENGTH=8         # Minimum password length
# FLUXBASE_AUTH_BCRYPT_COST=10                # BCrypt hashing cost (4-31)

############
# Email Configuration (SMTP)
############

# Email is disabled by default. Enable for production to support:
# - Email verification for new users
# - Password reset functionality
# - Magic link authentication

# Enable email functionality
FLUXBASE_EMAIL_ENABLED=false

# Email provider: smtp, sendgrid, mailgun, ses
FLUXBASE_EMAIL_PROVIDER=smtp

# Email sender details
FLUXBASE_EMAIL_FROM_ADDRESS=noreply@example.com
FLUXBASE_EMAIL_FROM_NAME=Wayli

# SMTP Configuration (required if FLUXBASE_EMAIL_ENABLED=true and provider=smtp)
# For local development, consider using Mailhog or similar SMTP testing tool
#
# Examples:
# - Gmail: smtp.gmail.com:587 (requires app-specific password)
# - SendGrid: smtp.sendgrid.net:587
# - AWS SES: email-smtp.region.amazonaws.com:587
# - Office 365: smtp.office365.com:587
#
# FLUXBASE_EMAIL_SMTP_HOST=smtp.gmail.com
# FLUXBASE_EMAIL_SMTP_PORT=587
# FLUXBASE_EMAIL_SMTP_USERNAME=your-email@gmail.com
# FLUXBASE_EMAIL_SMTP_PASSWORD=your-app-specific-password
# FLUXBASE_EMAIL_SMTP_TLS=true

############
# Storage Configuration (MinIO/S3)
############

# MinIO ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Storage bucket name for trip images and exports
STORAGE_S3_BUCKET=trip-images

# S3 region (for MinIO compatibility, any value works)
AWS_DEFAULT_REGION=us-east-1

# Maximum upload size in bytes (Optional)
# Default: 2147483648 (2GB)
# Uncomment to customize:
# FLUXBASE_STORAGE_MAX_UPLOAD_SIZE=2147483648

############
# Realtime/WebSocket Configuration
############

# Realtime is enabled by default for live updates
# Maximum concurrent WebSocket connections (Optional)
# Default: 1000
# Uncomment to customize:
# FLUXBASE_REALTIME_MAX_CONNECTIONS=1000
# FLUXBASE_REALTIME_PING_INTERVAL=30s         # WebSocket ping interval
# FLUXBASE_REALTIME_PONG_TIMEOUT=60s          # WebSocket pong timeout

############
# Edge Functions Configuration
############

# Enable edge functions (set to "false" to disable)
FLUXBASE_FUNCTIONS_ENABLED=true

# Function timeouts and resource limits (Optional)
# Uncomment to customize - defaults shown in comments
# FLUXBASE_FUNCTIONS_DEFAULT_TIMEOUT=30       # Default timeout in seconds
# FLUXBASE_FUNCTIONS_MAX_TIMEOUT=300          # Maximum timeout (5 minutes)
# FLUXBASE_FUNCTIONS_DEFAULT_MEMORY_LIMIT=128 # Default memory in MB
# FLUXBASE_FUNCTIONS_MAX_MEMORY_LIMIT=1024    # Maximum memory (1GB)

############
# Application Configuration
############

# Site URL (where your Wayli web app is hosted)
# ⚠️  Update this for production deployments!
SITE_URL=http://localhost:4000

# Pelias endpoint for geocoding (reverse geocoding trips)
# Default: Wayli's public Pelias instance
# For production, consider self-hosting Pelias: https://github.com/pelias/pelias
PELIAS_ENDPOINT=https://pelias.wayli.app

############
# Wayli Application
############

# Wayli Docker image version
WAYLI_VERSION=v2.0.0-rc.1

# Wayli web server port
WAYLI_WEB_PORT=4000

# Application mode - controls how Wayli runs in the container
# Options:
#   - web: Run only the web server (nginx serving SvelteKit app)
#   - worker: Run only the background job worker
#   - combined: Run both web server and worker in a single container
# Default: web (for wayli-web service), worker (for wayli-worker service)
# Use combined mode for simpler single-container deployments
# APP_MODE=combined

############
# Worker Configuration
############

# Maximum number of concurrent jobs per worker process
# Adjust based on your server resources and job characteristics:
# - For CPU-intensive jobs (trip detection, distance calculation): 2-3
# - For I/O-bound jobs (data import, geocoding): 3-5
# With multiple worker containers, total capacity = MAX_CONCURRENT_JOBS × number of workers
# Default: 3
MAX_CONCURRENT_JOBS=3

# Maximum number of job retries before marking as failed
# Default: 3
MAX_JOB_RETRIES=3

############
# Security Settings (Optional)
############

# Global rate limiting (disabled by default)
# Enable in production to prevent API abuse
# FLUXBASE_SECURITY_ENABLE_GLOBAL_RATE_LIMIT=false

############
# Production Deployment Checklist
############
#
# Before deploying to production, ensure you:
# ✓ Changed all passwords and secrets (POSTGRES_PASSWORD, JWT_SECRET, MINIO_ROOT_PASSWORD)
# ✓ Generated production ANON_KEY and SERVICE_ROLE_KEY using your JWT_SECRET
# ✓ Updated PUBLIC_FLUXBASE_BASE_URL to your production domain
# ✓ Updated SITE_URL to your production domain
# ✓ Configured email (FLUXBASE_EMAIL_*) for password resets
# ✓ Set FLUXBASE_DEBUG=false
# ✓ Configured PELIAS_ENDPOINT for production use
# ✓ Review and adjust timeout/limit settings for your workload
# ✓ Consider enabling FLUXBASE_SECURITY_ENABLE_GLOBAL_RATE_LIMIT
#
############
