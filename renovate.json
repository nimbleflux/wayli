{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "mode": "full",
  "extends": ["config:recommended", ":semanticCommitTypeAll(chore)", "group:all"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge non-major dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Pin eslint to v9 until typescript-eslint v9 is stable",
      "matchPackageNames": ["eslint", "@eslint/js"],
      "allowedVersions": "9.x",
      "matchManagers": ["npm"]
    }
  ]
}
