# Wayli Environment Variables
# Copy this file to .env and .env.production and fill in your values

# ========================================
# FLUXBASE CONFIGURATION
# ========================================
# Your Fluxbase project URL (required)
PUBLIC_FLUXBASE_BASE_URL=http://127.0.0.1:8080

# Fluxbase anonymous key - safe to expose to client (required)
PUBLIC_FLUXBASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Fluxbase service role key - NEVER expose to client! (required for server-side operations)
# Used only in Edge Functions and worker processes
FLUXBASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Comma-separated list of trusted origins for CSRF protection (required for production)
# Example: https://yourdomain.com,https://www.yourdomain.com
PUBLIC_TRUSTED_ORIGINS=

# CORS configuration for Edge Functions (required for production)
# Use specific domain(s) instead of '*' in production
# Example: https://yourdomain.com
FLUXBASE_CORS_ALLOW_ORIGIN=*

# ========================================
# EXTERNAL SERVICES (Optional)
# ========================================
# Pexels API key for image search functionality
PEXELS_API_KEY=

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Node environment: development, production, test
NODE_ENV=development

# Application mode: web or worker
APP_MODE=web

# Server port
PORT=3000

# ========================================
# DATABASE CONFIGURATION (for migrations)
# ========================================
# Direct PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ========================================
# FEATURE FLAGS
# ========================================
# Enable debug logging (true/false)
ENABLE_DEBUG_LOGGING=false

# Enable performance monitoring (true/false)
ENABLE_PERFORMANCE_MONITORING=false
