# Wayli Environment Variables
# Copy this file to .env and .env.production and fill in your values

# ========================================
# FLUXBASE CONFIGURATION
# ========================================
# Your Fluxbase project URL (required)
PUBLIC_FLUXBASE_BASE_URL=http://127.0.0.1:8080

# Fluxbase anonymous key - safe to expose to client (required)
# Signed with JWT_SECRET=dev-secret-key-change-in-production
PUBLIC_FLUXBASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6ImZsdXhiYXNlIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE3OTk1MzU2MDB9.peoT2zMOvonCJSM4ohHFKiHqJ0-TsjAF8tKU-aZfjAA

# Fluxbase service role key - NEVER expose to client! (required for server-side operations)
# Used only in Edge Functions and worker processes
# Signed with JWT_SECRET=dev-secret-key-change-in-production
FLUXBASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiZmx1eGJhc2UiLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.eyERh0zpGDlsWzjINl0gfyBy1JVWtJ83jtiPbefs2Xo

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Comma-separated list of trusted origins for CSRF protection (required for production)
# Example: https://yourdomain.com,https://www.yourdomain.com
PUBLIC_TRUSTED_ORIGINS=

# CORS configuration for Edge Functions (required for production)
# Use specific domain(s) instead of '*' in production
# Example: https://yourdomain.com
FLUXBASE_CORS_ALLOW_ORIGIN=*

# ========================================
# EXTERNAL SERVICES (Optional)
# ========================================
# Pexels API key for image search functionality
PEXELS_API_KEY=

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Node environment: development, production, test
NODE_ENV=development

# Application mode: web or worker
APP_MODE=web

# Server port
PORT=4000

# ========================================
# WORKER CONFIGURATION
# ========================================
# Maximum number of concurrent jobs per worker process (default: 5)
# Adjust based on your server resources and job characteristics
# Recommended: 2-5 for CPU-intensive jobs, 5-10 for I/O-bound jobs
MAX_CONCURRENT_JOBS=3

# Maximum number of job retries before marking as failed (default: 3)
MAX_JOB_RETRIES=3

# ========================================
# DATABASE CONFIGURATION (for migrations)
# ========================================
# Direct PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ========================================
# FEATURE FLAGS
# ========================================
# Enable debug logging (true/false)
ENABLE_DEBUG_LOGGING=false

# Enable performance monitoring (true/false)
ENABLE_PERFORMANCE_MONITORING=false
