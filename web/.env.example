# Wayli Environment Variables
# Copy this file to .env and .env.production and fill in your values

# ========================================
# FLUXBASE CONFIGURATION
# ========================================
# Public Fluxbase URL - accessible from browsers (required for client-side)
# This is the externally-accessible URL that browsers will use to connect
FLUXBASE_PUBLIC_BASE_URL=http://127.0.0.1:8080

# Internal Fluxbase URL - for server-to-server communication (optional)
# In Kubernetes, this points to the internal service (e.g., http://fluxbase:8080)
# If not set, FLUXBASE_PUBLIC_BASE_URL is used for server-side requests
# FLUXBASE_BASE_URL=http://fluxbase:8080

# Fluxbase anonymous key - safe to expose to client (required)
# Signed with JWT_SECRET=dev-secret-key-change-in-production
PUBLIC_FLUXBASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6ImZsdXhiYXNlIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE3OTk1MzU2MDB9.peoT2zMOvonCJSM4ohHFKiHqJ0-TsjAF8tKU-aZfjAA

# Fluxbase service role key - NEVER expose to client! (required for server-side operations)
# Used only in Edge Functions and worker processes
# Signed with JWT_SECRET=dev-secret-key-change-in-production
FLUXBASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiZmx1eGJhc2UiLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.eyERh0zpGDlsWzjINl0gfyBy1JVWtJ83jtiPbefs2Xo

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Node environment: development, production, test
NODE_ENV=development

# Application mode: web or worker
APP_MODE=web

# Server port
PORT=4000
