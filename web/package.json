{
	"name": "web",
	"private": true,
	"version": "2.0.0-rc.63",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:all": "npm run sync:all && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:accessibility": "vitest --run tests/accessibility/",
		"test:accessibility:watch": "vitest tests/accessibility/",
		"test:integration": "vitest --run tests/integration/",
		"test:integration:watch": "vitest tests/integration/",
		"test:coverage": "vitest --run --coverage",
		"sync:functions": "fluxbase functions sync --namespace wayli --dir ./fluxbase/functions/",
		"sync:jobs": "fluxbase jobs sync --namespace wayli --dir ./fluxbase/jobs/",
		"sync:migrations": "fluxbase migrations sync --namespace wayli --dir ./fluxbase/migrations/",
		"sync:chatbots": "fluxbase chatbots sync --namespace wayli --dir ./fluxbase/chatbots/",
		"sync:rpc": "fluxbase rpc sync --namespace wayli --dir ./fluxbase/rpc/",
		"sync:all": "npm run sync:rpc && npm run sync:functions && npm run sync:jobs && npm run sync:chatbots && npm run sync:migrations",
		"check:separation": "node scripts/check-environment-separation.js"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^11.0.3",
		"@semantic-release/npm": "^12.0.1",
		"@semantic-release/release-notes-generator": "^14.0.1",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@types/leaflet.markercluster": "^1.5.5",
		"@types/qrcode": "^1.5.5",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-svelte": "^3.0.0",
		"eslint-plugin-unused-imports": "^4.1.4",
		"globals": "^16.0.0",
		"jsdom": "^26.1.0",
		"lucide-static": "^0.525.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"semantic-release": "^24.2.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@fluxbase/sdk": "^0.0.1-rc.111",
		"@melt-ui/svelte": "^0.86.6",
		"@svelte-plugins/datepicker": "^1.0.11",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@turf/turf": "^7.2.0",
		"@types/dompurify": "^3.0.5",
		"@types/jszip": "^3.4.0",
		"@types/leaflet": "^1.9.18",
		"@types/lodash-es": "^4.17.12",
		"@types/uuid": "^10.0.0",
		"clsx": "^2.1.0",
		"date-fns": "^4.1.0",
		"dompurify": "^3.3.1",
		"dotenv": "^16.5.0",
		"fast-xml-parser": "^5.2.5",
		"jszip": "^3.10.1",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3",
		"lightningcss": "^1.30.1",
		"lodash-es": "^4.17.21",
		"lucide-react": "^0.525.0",
		"lucide-svelte": "^0.344.0",
		"marked": "^15.0.12",
		"qrcode": "^1.5.4",
		"svelte-sonner": "^1.0.5",
		"tailwind-merge": "^2.6.0",
		"uuid": "^11.1.0",
		"zod": "^4.0.5"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "*"
	}
}
