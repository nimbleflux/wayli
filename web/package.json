{
	"name": "web",
	"private": true,
	"version": "2.0.3",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:all": "npm run sync:all && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:accessibility": "vitest --run tests/accessibility/",
		"test:accessibility:watch": "vitest tests/accessibility/",
		"test:integration": "vitest --run tests/integration/",
		"test:integration:watch": "vitest tests/integration/",
		"test:coverage": "vitest --run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"sync:functions": "fluxbase functions sync --namespace wayli --dir ../fluxbase/functions/",
		"sync:jobs": "fluxbase jobs sync --namespace wayli --dir ../fluxbase/jobs/",
		"sync:migrations": "fluxbase migrations sync --namespace wayli --dir ../fluxbase/migrations/",
		"sync:chatbots": "fluxbase chatbots sync --namespace wayli --dir ../fluxbase/chatbots/",
		"sync:rpc": "fluxbase rpc sync --namespace wayli --dir ../fluxbase/rpc/",
		"sync:mcp": "fluxbase mcp tool sync --namespace wayli --dir ../fluxbase/mcp-tools/",
		"sync:all": "npm run sync:rpc && npm run sync:functions && npm run sync:jobs && npm run sync:chatbots && npm run sync:mcp && npm run sync:migrations",
		"check:separation": "node scripts/check-environment-separation.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.58.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.3",
		"@semantic-release/npm": "^13.1.3",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/dompurify": "^3.2.0",
		"@types/jszip": "^3.4.1",
		"@types/leaflet": "^1.9.21",
		"@types/leaflet.markercluster": "^1.5.6",
		"@types/lodash-es": "^4.17.12",
		"@types/qrcode": "^1.5.6",
		"@types/uuid": "^11.0.0",
		"@vitalets/google-translate-api": "^9.2.1",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-svelte": "^3.14.0",
		"eslint-plugin-unused-imports": "^4.3.0",
		"globals": "^17.3.0",
		"jsdom": "^28.0.0",
		"lightningcss": "^1.31.1",
		"lucide-static": "^0.563.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"semantic-release": "^25.0.3",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@fluxbase/sdk": "^2026.2.2",
		"@melt-ui/svelte": "^0.86.6",
		"@svelte-plugins/datepicker": "^1.0.11",
		"@turf/turf": "^7.3.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dompurify": "^3.3.1",
		"dotenv": "^17.2.3",
		"fast-xml-parser": "^5.3.4",
		"jszip": "^3.10.1",
		"leaflet": "^1.9.4",
		"leaflet.markercluster": "^1.5.3",
		"lodash-es": "^4.17.23",
		"lucide-svelte": "^0.563.0",
		"marked": "^17.0.1",
		"qrcode": "^1.5.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "*"
	}
}
